# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is already in .gitignore.

MONGO_URI=mongodb://localhost:27017/rentos
PORT=3002
JWT_SECRET=change-me-to-a-long-random-string

# Anthropic (AI Legal Assistant)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Resend (Email)
RESEND_API_KEY=re_...
FROM_EMAIL=onboarding@resend.dev

# Twilio (SMS)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890

# Cloudinary (Image & Document Storage)
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# Firebase (Push Notifications)
# Provide the path to a service-account JSON file, or inline the JSON object.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Payment provider mode: 'simulated' | 'mtn_momo' | 'telecel_cash' | 'airteltigo_money'
PAYMENTS_PROVIDER_MODE=simulated

# Redis (optional — falls back to in-memory cache)
REDIS_URL=

# External ML Pricing Service (optional — falls back to local TypeScript model)
# ML_SERVICE_URL=http://localhost:8000
# Shared secret with the ML service — MUST be set in any exposed deployment.
# The ML service rejects unauthenticated calls when this is configured on both sides.
ML_API_KEY=

# Optional owner super-admin for first seed (leave empty to skip)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Set to 'true' to expose /api/docs (Swagger UI) in production
ENABLE_API_DOCS=false

# Docker Compose MongoDB credentials (required for docker compose up)
MONGO_ROOT_USERNAME=rentos
MONGO_ROOT_PASSWORD=change-me

# Node environment
NODE_ENV=development
