{
  "name": "rentos-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "prebuild": "cp ../shared/types/index.ts src/types/shared.ts 2>/dev/null || true",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "reseed": "tsx --env-file=.env src/reseed.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@sentry/node": "^10.51.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.4.1",
    "firebase-admin": "^13.7.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.3.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "openai": "^4.95.0",
    "pdfkit": "^0.15.2",
    "qrcode": "^1.5.4",
    "resend": "^6.9.4",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.0",
    "uuid": "^11.1.1",
    "winston": "^3.19.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.13.9",
    "@types/qrcode": "^1.5.6",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "tsx": "^4.20.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
